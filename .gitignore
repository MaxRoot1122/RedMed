*.dSYM

# Android / Gradle (created once opened in Android Studio per android/SETUP.md)
android/local.properties
android/.gradle/
android/build/
android/app/build/
android/.idea/
android/*.iml
android/captures/
android/.cxx/

# Google Maps API key (see config/google-api-key.example)
config/google-api-key
ios/RedMed/google-api-key
