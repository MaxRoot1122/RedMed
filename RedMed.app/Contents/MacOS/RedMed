#!/bin/bash
# macOS double-click launcher — runs the native iOS app in Simulator (SwiftUI).
CONTENTS="$(cd "$(dirname "$0")/.." && pwd)"
APP_BUNDLE="$(cd "${CONTENTS}/.." && pwd -P)"
REPO_ROOT="$(dirname "$APP_BUNDLE")"
LAUNCH_IOS="$REPO_ROOT/scripts/run-ios-simulator.sh"
LOG_DIR="${HOME}/Library/Logs/RedMed"
LOG_FILE="${LOG_DIR}/launch.log"

mkdir -p "$LOG_DIR"
{
  echo "=== $(date '+%Y-%m-%d %H:%M:%S') RedMed.app ==="
  echo "REPO_ROOT=$REPO_ROOT"
} >> "$LOG_FILE"

fail() {
  local msg="$1"
  echo "ERROR: $msg" >> "$LOG_FILE"
  osascript -e "display alert \"RedMed\" message \"${msg}\n\nDetails: ${LOG_FILE}\" as critical"
  exit 1
}

# Do not open RedMed.app inside Cursor/VS Code — it is an app bundle (folder), not a text file.
# Double-click this app in Finder, or use RedMed.command on the Desktop.

if [ ! -f "$LAUNCH_IOS" ]; then
  fail "Launcher script missing at scripts/run-ios-simulator.sh"
fi

if ! command -v xcodebuild >/dev/null 2>&1; then
  fail "Xcode not found. Install Xcode, then open ios/RedMed.xcodeproj and press Run."
fi

if ! bash "$LAUNCH_IOS" >> "$LOG_FILE" 2>&1; then
  fail "Simulator launch failed. Open the log file for the build error."
fi
