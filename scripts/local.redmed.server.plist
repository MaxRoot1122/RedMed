<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.redmed.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>source "REPO_ROOT/scripts/redmed-server.sh"; redmed_ensure_server "REPO_ROOT/RedMed.app/Contents/Resources/www"</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/Users/YOU/Library/Logs/RedMed/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/YOU/Library/Logs/RedMed/launchd.err.log</string>
</dict>
</plist>
